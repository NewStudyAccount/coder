<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.mapper.ProductSkuMapper">

    <resultMap id="ProductSkuResult" type="com.admin.entity.ProductSku">
        <id property="id" column="id"/>
        <result property="productId" column="product_id"/>
        <result property="name" column="name"/>
        <result property="specs" column="specs"/>
        <result property="price" column="price"/>
        <result property="originalPrice" column="original_price"/>
        <result property="stock" column="stock"/>
        <result property="image" column="image"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByProductId" resultMap="ProductSkuResult">
        SELECT * FROM mall_product_sku WHERE product_id = #{productId} ORDER BY id ASC
    </select>

    <select id="selectById" resultMap="ProductSkuResult">
        SELECT * FROM mall_product_sku WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mall_product_sku (product_id, name, specs, price, original_price, stock, image, status)
        VALUES (#{productId}, #{name}, #{specs}, #{price}, #{originalPrice}, #{stock}, #{image}, #{status})
    </insert>

    <update id="update">
        UPDATE mall_product_sku
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="specs != null">specs = #{specs},</if>
            <if test="price != null">price = #{price},</if>
            <if test="originalPrice != null">original_price = #{originalPrice},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="image != null">image = #{image},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM mall_product_sku WHERE id = #{id}
    </delete>

    <delete id="deleteByProductId">
        DELETE FROM mall_product_sku WHERE product_id = #{productId}
    </delete>

    <insert id="batchInsert">
        INSERT INTO mall_product_sku (product_id, name, specs, price, original_price, stock, image, status)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.productId}, #{item.name}, #{item.specs}, #{item.price}, #{item.originalPrice}, #{item.stock}, #{item.image}, #{item.status})
        </foreach>
    </insert>
</mapper>
