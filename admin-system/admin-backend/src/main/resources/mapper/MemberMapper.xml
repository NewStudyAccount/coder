<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.mapper.MemberMapper">

    <resultMap id="MemberResult" type="com.admin.entity.Member">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="avatar" column="avatar"/>
        <result property="level" column="level"/>
        <result property="points" column="points"/>
        <result property="balance" column="balance"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectList" resultMap="MemberResult">
        SELECT * FROM mall_member
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="MemberResult">
        SELECT * FROM mall_member WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="MemberResult">
        SELECT * FROM mall_member WHERE username = #{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mall_member (username, password, nickname, phone, email, avatar, level, points, balance, status)
        VALUES (#{username}, #{password}, #{nickname}, #{phone}, #{email}, #{avatar}, #{level}, #{points}, #{balance}, #{status})
    </insert>

    <update id="update">
        UPDATE mall_member
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="level != null">level = #{level},</if>
            <if test="status != null">status = #{status},</if>
            <if test="password != null and password != ''">password = #{password},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM mall_member WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM mall_member WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="updateBalance">
        UPDATE mall_member SET balance = #{balance} WHERE id = #{id}
    </update>

    <update id="updatePoints">
        UPDATE mall_member SET points = #{points} WHERE id = #{id}
    </update>
</mapper>
