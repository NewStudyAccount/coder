<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.mapper.CouponMapper">

    <resultMap id="CouponResult" type="com.admin.entity.Coupon">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="discount" column="discount"/>
        <result property="minAmount" column="min_amount"/>
        <result property="totalCount" column="total_count"/>
        <result property="remainCount" column="remain_count"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectList" resultMap="CouponResult">
        SELECT * FROM mall_coupon
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="CouponResult">
        SELECT * FROM mall_coupon WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mall_coupon (name, type, discount, min_amount, total_count, remain_count, start_time, end_time, status)
        VALUES (#{name}, #{type}, #{discount}, #{minAmount}, #{totalCount}, #{remainCount}, #{startTime}, #{endTime}, #{status})
    </insert>

    <update id="update">
        UPDATE mall_coupon
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="discount != null">discount = #{discount},</if>
            <if test="minAmount != null">min_amount = #{minAmount},</if>
            <if test="totalCount != null">total_count = #{totalCount},</if>
            <if test="remainCount != null">remain_count = #{remainCount},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM mall_coupon WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM mall_coupon WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="updateStatus">
        UPDATE mall_coupon SET status = #{status} WHERE id = #{id}
    </update>
</mapper>
