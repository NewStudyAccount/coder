<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.mapper.OrderMapper">

    <resultMap id="OrderResult" type="com.admin.entity.Order">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="memberId" column="member_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="payTime" column="pay_time"/>
        <result property="payType" column="pay_type"/>
        <result property="status" column="status"/>
        <result property="receiverName" column="receiver_name"/>
        <result property="receiverPhone" column="receiver_phone"/>
        <result property="receiverAddress" column="receiver_address"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="memberName" column="member_name"/>
    </resultMap>

    <select id="selectList" resultMap="OrderResult">
        SELECT o.*, m.nickname AS member_name
        FROM mall_order o
        LEFT JOIN mall_member m ON o.member_id = m.id
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND o.order_no LIKE CONCAT('%', #{orderNo}, '%')
            </if>
            <if test="memberId != null">
                AND o.member_id = #{memberId}
            </if>
            <if test="status != null">
                AND o.status = #{status}
            </if>
        </where>
        ORDER BY o.create_time DESC
    </select>

    <select id="selectById" resultMap="OrderResult">
        SELECT o.*, m.nickname AS member_name
        FROM mall_order o
        LEFT JOIN mall_member m ON o.member_id = m.id
        WHERE o.id = #{id}
    </select>

    <select id="selectByOrderNo" resultMap="OrderResult">
        SELECT o.*, m.nickname AS member_name
        FROM mall_order o
        LEFT JOIN mall_member m ON o.member_id = m.id
        WHERE o.order_no = #{orderNo}
    </select>

    <update id="updateStatus">
        UPDATE mall_order SET status = #{status} WHERE id = #{id}
    </update>
</mapper>
