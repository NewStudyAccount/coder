<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.mapper.DeptMapper">

    <resultMap id="DeptResult" type="com.admin.entity.Dept">
        <id property="id" column="id"/>
        <result property="deptName" column="dept_name"/>
        <result property="parentId" column="parent_id"/>
        <result property="sort" column="sort"/>
        <result property="leader" column="leader"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectList" resultMap="DeptResult">
        SELECT * FROM sys_dept
        <where>
            <if test="deptName != null and deptName != ''">
                AND dept_name LIKE CONCAT('%', #{deptName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort ASC
    </select>

    <select id="selectById" resultMap="DeptResult">
        SELECT * FROM sys_dept WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_dept (dept_name, parent_id, sort, leader, status)
        VALUES (#{deptName}, #{parentId}, #{sort}, #{leader}, #{status})
    </insert>

    <update id="update">
        UPDATE sys_dept
        <set>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="leader != null">leader = #{leader},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_dept WHERE id = #{id}
    </delete>

    <select id="selectByParentId" resultMap="DeptResult">
        SELECT * FROM sys_dept WHERE parent_id = #{parentId} ORDER BY sort ASC
    </select>
</mapper>
